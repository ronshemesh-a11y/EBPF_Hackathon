/bin/
# Compiled server binary (built from source; never commit the artifact)
/server

# Never commit secrets — the Slack webhook URL is passed via $SLACK_WEBHOOK_URL
# or --slack-webhook, not stored in the repo. Ignore common local secret files.
.env
.env.*
*.local
results.json
run_*.json

# SQLite verdict history (created at runtime by cmd/server)
*.db
*.db-journal
*.db-wal
*.db-shm
